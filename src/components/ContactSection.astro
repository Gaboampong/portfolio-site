---
import SectionHeading from './SectionHeading.astro';
---

<section id="contact" class="mx-auto max-w-6xl px-5 py-10 sm:px-6 lg:px-8">
  <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
    <div class="reveal">
      <SectionHeading
        eyebrow="Contact"
        title="Available for data-focused roles and practical problem solving"
        lead="I am especially well suited to work involving reporting systems, SQL-heavy analysis, BI dashboards, monitoring workflows, and operational data improvement."
      />
    </div>

    <div class="reveal rounded-[2rem] border border-white/10 bg-white/6 p-6 backdrop-blur">
      <div class="space-y-4">
        <a class="block rounded-2xl border border-white/10 bg-white/6 p-4 transition hover:border-cyan-300/35 hover:bg-white/8" href="mailto:gabrieladjei0@gmail.com">
          <p class="font-mono text-xs uppercase tracking-[0.24em] text-cyan-300/80">Email</p>
          <p class="mt-2 text-base font-medium text-white">gabrieladjei0@gmail.com</p>
        </a>
        <a class="block rounded-2xl border border-white/10 bg-white/6 p-4 transition hover:border-cyan-300/35 hover:bg-white/8" href="https://www.linkedin.com/in/gabrielboampong">
          <p class="font-mono text-xs uppercase tracking-[0.24em] text-cyan-300/80">LinkedIn</p>
          <p class="mt-2 text-base font-medium text-white">linkedin.com/in/gabrielboampong</p>
        </a>
        <a class="block rounded-2xl border border-white/10 bg-white/6 p-4 transition hover:border-cyan-300/35 hover:bg-white/8" href="tel:+233242931397">
          <p class="font-mono text-xs uppercase tracking-[0.24em] text-cyan-300/80">Phone</p>
          <p class="mt-2 text-base font-medium text-white">+233 24 293 1397</p>
        </a>
      </div>
    </div>
  </div>
</section>
