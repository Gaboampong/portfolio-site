---
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, lead, align = 'left' } = Astro.props;
const centered = align === 'center';
---

<div class:list={[
  'mb-10 max-w-3xl',
  centered && 'mx-auto text-center'
]}>
  <p class="font-mono text-xs font-semibold uppercase tracking-[0.28em] text-cyan-300/80">{eyebrow}</p>
  <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">{title}</h2>
  <p class="mt-4 text-base leading-8 text-slate-300">{lead}</p>
</div>
