---
import SectionHeading from './SectionHeading.astro';

const timeline = [
  {
    period: 'Apr 2025 - Present',
    role: 'Database Engineer',
    company: 'DS7 Limited',
    outcomes: [
      'Design and maintain scalable databases to support operational applications.',
      'Write and optimize SQL queries for extraction, analysis, and reporting.',
      'Build reporting outputs in Power BI and Excel while validating data quality across systems.',
    ],
  },
  {
    period: 'Nov 2023 - Sept 2024',
    role: 'Monitoring and Evaluation Trainee',
    company: 'Universal Engineering and Consultancy Services Limited',
    outcomes: [
      'Analyzed fuel consumption, delivery schedules, and stock-level data.',
      'Monitored systems for data accuracy and compliance across reporting workflows.',
      'Supported corrective action on stock discrepancies and day-to-day IT issues.',
    ],
  },
  {
    period: 'Oct 2022 - Dec 2022',
    role: 'Information Systems and Security Intern',
    company: 'Npontu Technologies Limited',
    outcomes: [
      'Built Grafana dashboards to improve visibility into systems and data.',
      'Researched cloud computing options to support scalability and decision-making.',
      'Monitored systems for integrity and security-related issues.',
    ],
  },
  {
    period: 'Nov 2021 - Dec 2021',
    role: 'IT and Automation Intern',
    company: 'Universal Engineering and Consultancy Services Limited',
    outcomes: [
      'Supported research into automation and fuel-level indicator development.',
      'Handled troubleshooting and data processing tasks tied to project delivery.',
      'Configured and maintained network systems to improve technical performance.',
    ],
  },
];

const analyticsSkills = ['SQL', 'Power BI', 'Excel', 'Power Query', 'Grafana', 'Tableau', 'SAP BO', 'Data Validation'];
const engineeringSkills = ['Python', 'PostgreSQL', 'MySQL', 'SQLite', 'Docker Basics', 'GitHub', 'Systems Monitoring', 'Technical Documentation'];
---

<section id="experience" class="mx-auto max-w-6xl px-5 py-10 sm:px-6 lg:px-8">
  <SectionHeading
    eyebrow="Experience"
    title="Built around reliability, visibility, and data quality"
    lead="Each role sharpened the same core ability: taking imperfect operational information and turning it into something structured, accurate, and useful."
  />

  <div class="grid gap-5 lg:grid-cols-[1fr_0.9fr]">
    <div class="reveal rounded-[2rem] border border-white/10 bg-white/6 p-7 backdrop-blur">
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.28em] text-cyan-300/80">Career path</p>
      <div class="mt-6 space-y-6">
        {timeline.map((item) => (
          <article class="relative border-l border-cyan-300/30 pl-6">
            <span class="absolute left-[-5px] top-1 h-2.5 w-2.5 rounded-full bg-cyan-300 shadow-[0_0_18px_rgba(103,232,249,0.6)]"></span>
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-cyan-300/80">{item.period}</p>
            <h3 class="mt-3 text-xl font-semibold text-white">{item.role}</h3>
            <p class="mt-1 text-sm font-medium text-amber-200">{item.company}</p>
            <ul class="mt-4 space-y-2 text-sm leading-7 text-slate-300">
              {item.outcomes.map((outcome) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-300"></span>
                  <span>{outcome}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>

    <div class="grid gap-5">
      <article class="reveal rounded-[2rem] border border-white/10 bg-white/6 p-6 backdrop-blur">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.28em] text-cyan-300/80">Analytics and BI</p>
        <div class="mt-5 flex flex-wrap gap-3">
          {analyticsSkills.map((skill) => (
            <span class="rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm text-slate-200">{skill}</span>
          ))}
        </div>
      </article>

      <article class="reveal rounded-[2rem] border border-white/10 bg-white/6 p-6 backdrop-blur">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.28em] text-cyan-300/80">Engineering stack</p>
        <div class="mt-5 flex flex-wrap gap-3">
          {engineeringSkills.map((skill) => (
            <span class="rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm text-slate-200">{skill}</span>
          ))}
        </div>
      </article>

      <article class="reveal rounded-[2rem] border border-cyan-300/20 bg-cyan-300/10 p-6 backdrop-blur">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.28em] text-cyan-200">Professional edge</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Calm, detailed, and effective in real operational environments.</h3>
        <p class="mt-4 text-sm leading-7 text-slate-200/90">
          I bring structure to reporting and data workflows that would otherwise remain inconsistent, slow, or difficult to trust.
        </p>
      </article>
    </div>
  </div>
</section>
